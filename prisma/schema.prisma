generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  clerkId   String   @unique
  createdAt DateTime @default(now())

  workflows     Workflow[]
  workflowRuns  WorkflowRun[]
}

model Workflow {
  id        String   @id @default(cuid())
  userId    String
  name      String
  nodes     Json
  edges     Json
  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowRuns WorkflowRun[]
  nodeResults  NodeResult[]

  @@index([userId])
  @@index([userId, deletedAt])
}

model WorkflowRun {
  id          String          @id @default(cuid())
  workflowId  String
  userId      String
  status      RunStatus
  scope       RunScope
  durationMs  Int?
  startedAt   DateTime        @default(now())
  completedAt DateTime?

  workflow       Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeExecutions NodeExecution[]

  @@index([workflowId])
  @@index([userId])
  @@index([userId, status])
  @@index([workflowId, status])
}

model NodeExecution {
  id          String              @id @default(cuid())
  runId       String
  nodeId      String
  nodeType    String
  status      NodeExecutionStatus
  inputs      Json
  output      Json?
  error       Json?
  executionMs Int?
  createdAt   DateTime            @default(now())

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, nodeId])
  @@index([nodeType])
}

model NodeResult {
  id         String   @id @default(cuid())
  workflowId String
  nodeId     String
  inputHash  String
  output     Json
  updatedAt  DateTime @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, nodeId, inputHash])
  @@index([workflowId])
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum RunScope {
  LOCAL
  CLOUD
  SANDBOX
}

enum NodeExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}